<launch>
    <!-- Standalone post-processing node for voxelization + high-heat filtering + clustering. -->
    <arg name="input_topic" default="/active_mapping/global_map"/>
    <arg name="frame_id" default="world"/>
    <arg name="voxel_leaf_size" default="0.15"/>
    <arg name="heat_threshold" default="0.55"/>
    <arg name="cluster_tolerance" default="0.35"/>
    <arg name="cluster_min_size" default="20"/>
    <arg name="cluster_max_size" default="200000"/>

    <node pkg="active_mapping" type="heatmap_cluster_node" name="heatmap_cluster_node" output="screen">
        <param name="input_topic" value="$(arg input_topic)"/>
        <param name="frame_id" value="$(arg frame_id)"/>
        <param name="voxel_leaf_size" value="$(arg voxel_leaf_size)"/>
        <param name="heat_threshold" value="$(arg heat_threshold)"/>
        <param name="cluster_tolerance" value="$(arg cluster_tolerance)"/>
        <param name="cluster_min_size" value="$(arg cluster_min_size)"/>
        <param name="cluster_max_size" value="$(arg cluster_max_size)"/>
    </node>
</launch>
